{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "lint": "npm run lint:js",
        "lint:php": "composer lint:php",
        "lint:js": "eslint \"resources/js/**/*.{js,vue}\"",
        "format": "npm run format:js",
        "format:js": "prettier --write \"resources/js/**/*.{js,vue}\" \"docs/**/*.md\" \"*.{json,md}\"",
        "format:check": "prettier --check \"resources/js/**/*.{js,vue}\" \"docs/**/*.md\" \"*.{json,md}\"",
        "test": "npm run test:php",
        "test:php": "php artisan test",
        "build": "vite build",
        "dev": "vite"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@inertiajs/vue3": "^2.0.0",
        "@tailwindcss/forms": "^0.5.3",
        "@tailwindcss/vite": "^4.0.0",
        "@vitejs/plugin-vue": "^6.0.0",
        "eslint": "^9.25.1",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-vue": "^9.33.0",
        "autoprefixer": "^10.4.12",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "globals": "^15.13.0",
        "laravel-vite-plugin": "^2.0.0",
        "postcss": "^8.4.31",
        "prettier": "^3.3.3",
        "tailwindcss": "^3.2.1",
        "vue-eslint-parser": "^9.4.3",
        "vite": "^7.0.7",
        "vue": "^3.4.0"
    },
    "dependencies": {
        "@fontsource/be-vietnam-pro": "^5.2.8",
        "@iconify-icons/iconoir": "^1.2.30",
        "@iconify-icons/la": "^1.2.3",
        "@iconify/vue": "^5.0.0",
        "lucide-vue-next": "^0.577.0",
        "qrcode": "^1.5.4"
    }
}
