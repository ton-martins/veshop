APP_NAME=Veshop
APP_ENV=production
APP_KEY=suachavesecreta
APP_DEBUG=false
APP_URL=https://www.veshop.com.br
APP_FORCE_HTTPS=true
APP_FORCE_ROOT_URL=false

APP_LOCALE=pt_BR
APP_TIMEZONE=America/Sao_Paulo
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=veshop_mysql
DB_PORT=3306
DB_DATABASE=veshop
DB_USERNAME=mysql
DB_PASSWORD=suasenha

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.veshop.com.br
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SHOP_VERIFICATION_DEBUG=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
REPORT_EXPORTS_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=veshop_redis
REDIS_PASSWORD=suasenha
REDIS_PORT=6379
REDIS_QUEUE_BLOCK_FOR=5
REDIS_QUEUE_AFTER_COMMIT=true

MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=contato@veshop.com.br
MAIL_PASSWORD=suasenha
MAIL_FROM_ADDRESS="contato@veshop.com.br"
MAIL_FROM_NAME=Veshop

MERCADOPAGO_BASE_URL=https://api.mercadopago.com
MERCADOPAGO_TIMEOUT=15

IBGE_BASE_URL=https://servicodados.ibge.gov.br
IBGE_TIMEOUT=10

SECURITY_HEADERS_ENABLED=true
HSTS_ENABLED=true
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=false

VITE_APP_NAME=Veshop
